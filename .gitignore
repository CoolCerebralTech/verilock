cat > .gitignore << 'EOF'
# Secrets — never commit these
**/.env
*.pem
*.key

# Go
core/data/
core/*.db
core/*.db-wal
core/*.db-shm

# Solidity build artifacts
contracts/out/
contracts/cache/
contracts/broadcast/

# TypeScript
sdk/node_modules/
sdk/dist/

# OS
.DS_Store
Thumbs.db
Thumbs.db:encdata
EOF
# Secrets — NEVER commit
.env
.env.local
.env.production
data/*.key
data/*.secret
cache/
broadcast/

git/
