# Tollgate Deployment Environment (Base Sepolia)
# Copy this to .env and fill in your values

# Your deployer private key (with 0x prefix) — NEVER commit this
DEPLOYER_PRIVATE_KEY=

# Notary address (from Notary startup log)
TOLLGATE_NOTARY_ADDRESS=

# Safe address (create at app.safe.global on Base Sepolia)
SAFE_ADDRESS=

# BaseScan API key (free at basescan.org)
BASESCAN_API_KEY=

# Set after deploying the Guard
GUARD_ADDRESS=

# Prevent accidental mainnet deployments
EXPECTED_CHAIN_ID=84532
